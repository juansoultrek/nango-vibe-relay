# Copy this file to `.env` for local development (`npm run dev` loads it if you use dotenv — see README).
# This project uses process.env only; for local dev you can export variables in your shell instead.

# Required for AI step
OPENAI_API_KEY=

# Nango (https://nango.dev) — server secret from the Nango dashboard
NANGO_SECRET_KEY=
# Base URL for Nango API (omit to use default EU/US host from your account docs)
# NANGO_HOST=https://api.nango.dev

# Integration config unique to your Nango account — use the Integration ID from Nango
NANGO_PROVIDER_CONFIG_KEY_GOOGLE_SHEETS=google-sheet
NANGO_PROVIDER_CONFIG_KEY_SLACK=slack

# OAuth connection IDs created in Nango (after you connect Google + Slack in the Nango UI/API)
NANGO_CONNECTION_ID_GOOGLE=
NANGO_CONNECTION_ID_SLACK=

# Google Sheets target
GOOGLE_SPREADSHEET_ID=
GOOGLE_SHEETS_RANGE=Sheet1!A1

# Slack target (channel ID, e.g. C0123456789)
SLACK_CHANNEL_ID=

# HTTP port (optional). On cPanel Node.js, the platform usually sets PORT automatically.
# PORT=8787
