# Copy this file to `.env` for local development (`npm run dev` loads it if you use dotenv — see README).
# This project uses process.env only; for local dev you can export variables in your shell instead.

# Required for the AI step (/submit pipeline)
OPENAI_API_KEY=
# Optional — default gpt-4o-mini (cheap; JSON response_format is supported on recent models)
# OPENAI_MODEL=gpt-4o-mini

# Nango (https://nango.dev) — server secret from the Nango dashboard
NANGO_SECRET_KEY=
# Base URL for Nango API (omit to use default EU/US host from your account docs)
# NANGO_HOST=https://api.nango.dev

# Integration config unique to your Nango account — use the Integration ID from Nango
NANGO_PROVIDER_CONFIG_KEY_GOOGLE_SHEETS=google-sheet
NANGO_PROVIDER_CONFIG_KEY_SLACK=slack

# OAuth connection IDs created in Nango (after you connect Google + Slack in the Nango UI/API)
NANGO_CONNECTION_ID_GOOGLE=
NANGO_CONNECTION_ID_SLACK=

# Google Sheets target (append uses values.append + USER_ENTERED so column formatting applies like normal rows)
GOOGLE_SPREADSHEET_ID=
# Tab *title* as shown in the sheet tab (default Sheet1). Must match your spreadsheet’s tab name.
# GOOGLE_SHEETS_TAB=Sheet1
# Write Spanish column headers to A1:E1 once when cell A1 is empty (set to false to skip).
# GOOGLE_SHEETS_ENSURE_HEADERS=true
# Default: timestamp column A is a numeric datetime serial (format as date in Sheets). Set true for raw ISO strings.
# GOOGLE_SHEETS_TIMESTAMP_AS_TEXT=false
# Tab id from Sheets URL (...#gid=0); legacy health/debug only (values API uses tab name above)
GOOGLE_SHEETS_TAB_ID=0
# Optional alias for tooling
# GOOGLE_SHEETS_GID=0
# Legacy / unused
# GOOGLE_SHEETS_RANGE=

# Optional: POST /test/sheets returns { debug: { providerPath, nangoProxyUrl, ... } } on failure + stderr logs. Unset in production after fixing.
# SHEETS_DEBUG=1   # optional; curl /health shows sheetsDebugEnvRaw so you can verify the process sees it

# Slack target (channel ID, e.g. C0123456789)
SLACK_CHANNEL_ID=

# HTTP port (optional). Managed Node hosts normally set PORT automatically.
# PORT=8787

# Optional URL prefix — no trailing slash.
# Also accepts BASE_PATH / APPLICATION_BASE_PATH as fallbacks after APP_BASE_PATH.
# APP_BASE_PATH=/nango

# Managed hosts often set PORT — if APP_BASE_PATH is absent, mounts APP_BASE_FALLBACK_MOUNT (default /nango).
# Set APP_BASE_AUTO_NANGO=false if you use PORT locally and need root mount (/).
# APP_BASE_FALLBACK_MOUNT=/nango
# APP_BASE_AUTO_NANGO=false
