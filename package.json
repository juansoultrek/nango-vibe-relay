{
  "name": "nango-vibe-relay",
  "version": "0.1.0",
  "private": false,
  "description": "Nango Vibe Relay — mood id + message through OpenAI, Google Sheets & Slack via Nango, polled step logs.",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "dev": "node --env-file=.env ./node_modules/tsx/dist/cli.mjs watch src/server.ts",
    "typecheck": "tsc -p tsconfig.build.json --noEmit"
  },
  "dependencies": {
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.4",
    "@types/node": "^24.9.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
